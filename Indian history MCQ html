{q:"প্ৰথম বৌদ্ধ মহাসভা ক'ত হৈছিল?",a:["ৰাজগৃহ","বৈশালী","পাটালীপুত্ৰ","কনৌজ"],correct:0},
{q:"জৈন ধৰ্মৰ মূল নীতি নহয় কোনটো?",a:["সঁচা কথা","চুৰ নকৰা","অহিংসা","পিতৃ-মাতৃ সন্মান"],correct:3},
{q:"জৈন ধৰ্মৰ ভাগ দুটা কি?",a:["হীনযান-মহাযান","শ্বেতাম্বৰ-দিগম্বৰ","কোনোটাই নহয়","কেথলিক"],correct:1},
{q:"বৌদ্ধ ধৰ্মৰ ভাগ দুটা কি?",a:["হীনযান-মহাযান","শ্বেতাম্বৰ-দিগম্বৰ","কোনোটাই নহয়","কেথলিক"],correct:0},
{q:"মৌৰ্য সাম্ৰাজ্যৰ প্ৰতিষ্ঠাতা কোন?",a:["চন্দ্ৰগুপ্ত","বিম্বিসাৰ","অশোক","কোনোটাই নহয়"],correct:0},
{q:"অর্থশাস্ত্র কোনে লিখিছিল?",a:["কৌটিল্য","মেগাস্থেনিছ","চৰক","বিশাখাদত্ত"],correct:0},
{q:"ইণ্ডিকা গ্ৰন্থখন কাৰ?",a:["কৌটিল্য","মেগাস্থেনিছ","চৰক","কালিদাস"],correct:1},
{q:"কালিদাসে কোনখন ৰচনা কৰা নাছিল?",a:["শকুন্তলা","মেঘদূত","মুদ্রাৰাক্ষস","মালৱিকা"],correct:2},
{q:"হাথীগুম্ফা শিলালিপি কাৰ?",a:["অশোক","কণিষ্ক","খাৰৱেল","হৰ্ষ"],correct:2},
{q:"গ্ৰীকসকলক কি নামেৰে জনা যায়?",a:["যবন","কুশান","শক","কোনোটাই নহয়"],correct:0},
{q:"যবনিকা শব্দটো কাৰ অৱদান?",a:["গ্ৰীক","কুশান","গুপ্ত","মৌৰ্য"],correct:0},
{q:"চতুৰ্থ বৌদ্ধ মহাসভা কাৰ সময়ত?",a:["অশোক","কণিষ্ক","অজাতশত্ৰু","কোনোটাই নহয়"],correct:1},
{q:"বুদ্ধচৰিত কোনে লিখিছিল?",a:["হৰ্ষ","অশ্বঘোষ","কালিদাস","চৰক"],correct:1},

/* ===== SET 2 ===== */

{q:"বিক্ৰমাদিত্য উপাধি কোনে গ্ৰহণ কৰিছিল?",a:["অশোক","সমুদ্রগুপ্ত","চন্দ্ৰগুপ্ত I","চন্দ্ৰগুপ্ত II"],correct:3},
{q:"গুপ্ত যুগত ভাৰতলৈ অহা পৰ্যটক কোন?",a:["হিউৱেন চাং","ফাহিয়ান","আলবেৰুণী","মেগাস্থেনিছ"],correct:1},
{q:"দশমিক পদ্ধতিৰ বিজ্ঞানী কোন?",a:["আৰ্যভট্ট","বৰাহমিহিৰ","ব্ৰহ্মগুপ্ত","চৰক"],correct:0},
{q:"মৃচ্ছকটিকম লেখক কোন?",a:["কালিদাস","বিশাখদত্ত","শূদ্ৰক","অশ্বঘোষ"],correct:2},
{q:"হর্ষবর্ধনে কোনখন নালিখা?",a:["নাগানন্দ","ৰত্নাবলী","প্ৰিয়দৰ্শিকা","মুদ্রাৰাক্ষস"],correct:3},
{q:"নালন্দা প্ৰথম উপাচাৰ্য?",a:["শীলভদ্ৰ","হিউৱেন চাং","অশ্বঘোষ","কোনোটাই নহয়"],correct:0},
{q:"হিউৱেন চাং কেতিয়া আহিছিল?",a:["630","644","647","নাই"],correct:0},
{q:"সি-ইউ-কি গ্ৰন্থৰ লেখক?",a:["ফাহিয়ান","হিউৱেন চাং","হুই লি","নাই"],correct:1},
{q:"মহাবলিপুৰম মন্দিৰ কোনে নিৰ্মাণ কৰিছিল?",a:["মহেন্দ্ৰ","নৰসিংহ II","ৰাজেন্দ্ৰ","নাই"],correct:1},
{q:"সিন্ধ জয় কৰা সেনাপতি?",a:["ঘোৰী","বিন কাছিম","গজনী","খিলজী"],correct:1},
{q:"তৰাইন যুদ্ধ কাৰ মাজত?",a:["ঘোৰী-পৃথ্বীৰাজ","বাবৰ-সংগ্রাম","মামুদ-জয়পাল","নাই"],correct:0},
{q:"কুতুব মিনাৰ আৰম্ভ কৰিছিল?",a:["ইলতুতমিছ","আইবক","আকবৰ","নাই"],correct:1},
{q:"আলাই দৰৱাজা কোনে নিৰ্মাণ কৰিছিল?",a:["আকবৰ","আলাউদ্দিন","শাহজাহান","আইবক"],correct:1},
{q:"দাস বংশ প্ৰতিষ্ঠাতা?",a:["আইবক","আলাউদ্দিন","ইলতুতমিছ","নাই"],correct:0},
{q:"প্ৰথম মহিলা শাসক?",a:["ৰাজিয়া","গুলবদন","নুৰজাহান","নাই"],correct:0},
{q:"বিজয়নগৰ প্ৰতিষ্ঠাতা?",a:["বাহমন","হৰিহৰ-বুক্ক","বাবৰ","নাই"],correct:1},
{q:"টালিকোটা যুদ্ধ?",a:["1575","1565","1526","নাই"],correct:1},
{q:"প্ৰথম পানিপথ যুদ্ধ?",a:["1526","1556","1565","নাই"],correct:0},
{q:"হলদিঘাটি যুদ্ধ?",a:["1576","1565","1556","নাই"],correct:0}

];

let userAnswers=[];

function loadQuiz(){
const quiz=document.getElementById("quiz");

quizData.forEach((q,index)=>{
let div=document.createElement("div");
div.classList.add("question");

let html=`<p>${index+1}. ${q.q}</p>`;

q.a.forEach((opt,i)=>{
html+=`<button onclick="selectAnswer(${index},${i},this)">${opt}</button>`;
});

html+=`<p class="answer" id="ans${index}"></p>`;

div.innerHTML=html;
quiz.appendChild(div);
});
}

function selectAnswer(qIndex,ans,btn){
userAnswers[qIndex]=ans;

let buttons=btn.parentElement.querySelectorAll("button");
buttons.forEach(b=>{
b.style.background="#eee";
b.style.color="black";
});

btn.style.background="#4facfe";
btn.style.color="white";
}

function submitQuiz(){
let score=0;

document.querySelectorAll(".question").forEach((qDiv,i)=>{

let buttons=qDiv.querySelectorAll("button");

buttons.forEach((btn,index)=>{
if(index===quizData[i].correct){
btn.style.background="green";
btn.style.color="white";
}

if(userAnswers[i]===index && index!==quizData[i].correct){
btn.style.background="red";
btn.style.color="white";
}

btn.disabled=true;
});

document.getElementById("ans"+i).innerHTML=
"✔ Correct: "+quizData[i].a[quizData[i].correct];

if(userAnswers[i]===quizData[i].correct){
score++;
}

});

document.getElementById("result").innerHTML=
"🔥 Final Score: "+score+" / "+quizData.length;
}

loadQuiz();

</script>

</body>
</html>
